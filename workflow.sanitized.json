        "jsCode": "const rawPrompt = $input.item.json.content.replace('!anime', '').trim();\n// ↓ここをLoRAのトリガーワードに合わせて書き換えます\nconst magicPrompt = ', anime niji style, masterpiece, best quality';\nreturn { json: {\n  finalPrompt: rawPrompt + magicPrompt,\n  channelId: $input.item.json.channelId\n} };"
      },
