    {
      "parameters": {
        "method": "POST",
        "url": "https://fal.run/fal-ai/bytedance/seedream/v5/lite/text-to-image",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"prompt\": \"={{ $json.finalPrompt }}\",\n  \"image_size\": \"portrait_4_3\",\n  \"num_images\": 1,\n  \"max_images\": 1,\n  \"enable_safety_checker\": true\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        -352,
        -144
      ],
      "id": "REDACTED_NODE_ID",
      "name": "HTTP Request",
      "continueOnFail": true,
      "credentials": {
        "httpHeaderAuth": {
          "id": "REDACTED_CREDENTIAL_ID",
          "name": "REDACTED_CREDENTIAL_NAME"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\n\nconst imageUrl = response?.images?.[0]?.url ?? '';\nconst rawError = response?.error ?? response?.body ?? response?.data ?? response;\n\nlet errorText = '';\nif (!imageUrl) {\n  if (typeof rawError === 'string') {\n    errorText = rawError;\n  } else if (rawError?.message) {\n    errorText = rawError.message;\n  } else if (typeof rawError?.detail === 'string') {\n    errorText = rawError.detail;\n  } else if (Array.isArray(rawError?.detail) && rawError.detail[0]?.msg) {\n    errorText = rawError.detail[0].msg;\n  } else if (rawError?.detail?.message) {\n    errorText = rawError.detail.message;\n  } else {\n    errorText = JSON.stringify(rawError);\n  }\n}\n\nreturn {\n  json: {\n    imageUrl,\n    errorText: errorText || 'Unknown error'\n  }\n};"
      },
